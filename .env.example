# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit it.

# ── Backend ────────────────────────────────────────────────────────────────────
JWT_SECRET=<generate-with: openssl rand -hex 32>
OPENAI_API_KEY=sk-...

# ── Database (matches docker-compose.yml defaults) ─────────────────────────────
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3308/interviewprep?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=interviewprep
SPRING_DATASOURCE_PASSWORD=interviewprep123

# ── Redis ──────────────────────────────────────────────────────────────────────
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379

# ── Frontend ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
